# ============================================================================
# Template Variables Environnement
# Copier dans .env.local et remplir avec vos valeurs
# ⚠️ JAMAIS commit .env.local (elle est dans .gitignore)
# ============================================================================

# SUPABASE - Configuration
# Récupérer depuis Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key-here

# APPLICATION - Mode
VITE_APP_ENV=development
# Ou : VITE_APP_ENV=production pour build final

# SIMULATION (Backend Script)
# À utiliser dans scripts/simulate-realtime.ts
VITE_ELECTION_NAME=Présidentielle RDC 2026 (Simulation)
VITE_SIMULATION_DURATION_SECONDS=300
VITE_SIMULATION_BATCH_INTERVAL_MS=2500
VITE_ANOMALY_INJECTION_RATE=0.08

# ============================================================================
# INSTRUCTIONS
# ============================================================================
#
# 1. Créer un projet sur supabase.com
# 2. Attendre que la DB soit prête (~2 min)
# 3. Aller à Settings → API
# 4. Copier Project URL → VITE_SUPABASE_URL
# 5. Copier anon public → VITE_SUPABASE_ANON_KEY
# 6. Sauvegarder dans .env.local
# 7. Exécuter : npm run dev
# 8. Lancer simulation : npm run simulate
#
# ============================================================================
